# Earth-Agent API Configuration
# Copy this file to .env and fill in your actual API keys and URLs

# OpenAI API Configuration (GPT-5)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen / Alibaba DashScope OpenAI-compatible API Configuration
QWEN_API_KEY=your_qwen_or_dashscope_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Kimi K2 API Configuration
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1

# GLM-4.5 API Configuration
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Judge Model Configuration (for GRPO training)
# Can reuse the same API key as the main model if using the same provider
JUDGE_MODEL_API_KEY=your_judge_model_api_key_here
JUDGE_MODEL_BASE_URL=https://api.openai.com/v1

# Additional Configuration
# MODEL_TEMPERATURE=0.1
# MODEL_MAX_TOKENS=8192
# MODEL_TIMEOUT=120

# Frontend map configuration (Vite)
VITE_AMAP_KEY=your_amap_web_js_api_key_here
# VITE_AMAP_SECURITY_CODE=your_amap_security_code_here
# =============================================================================
# Database Configuration (PostgreSQL + PostGIS via Docker)
# =============================================================================
# Set DB_ENABLED=false to disable database and use file-only mode
DB_ENABLED=true
DB_HOST=localhost
DB_PORT=5433
DB_NAME=disaster_agent
DB_USER=disaster_agent
DB_PASSWORD=disaster_agent_pwd

# pgAdmin (optional, for visual management)
PGADMIN_EMAIL=admin@disaster-agent.local
PGADMIN_PASSWORD=admin

# =============================================================================
# Quick start:
#   cd docker && docker compose up -d
#   # DB will be available on localhost:5433
#   # pgAdmin UI on http://localhost:5050
#   # Schema auto-created from docker/initdb/01_schema.sql
# =============================================================================
